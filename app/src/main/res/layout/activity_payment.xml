<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7FB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#1F1F39"
                android:contentDescription="@string/back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/payment_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1F1F39" />

            <TextView
                android:id="@+id/txtPaymentTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Listing Title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPaymentAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Deposit: P500"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6C4DFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/choose_payment_method"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Card Payment -->
                <RadioButton
                    android:id="@+id/radioCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_payment" />

                <LinearLayout
                    android:id="@+id/layoutCardDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingStart="32dp"
                    android:paddingEnd="0dp"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/visa" android:background="#1A1F71" android:textColor="#FFFFFF" android:padding="4dp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mastercard" android:background="#EB001B" android:textColor="#FFFFFF" android:padding="4dp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/paypal" android:background="#003087" android:textColor="#FFFFFF" android:padding="4dp" android:textStyle="bold"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/editCardNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/card_number_hint"
                        android:inputType="number"
                        android:maxLength="16" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/editExpiry"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/expiry_date_hint"
                            android:inputType="date" />
                        <EditText
                            android:id="@+id/editCVV"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/cvv_hint"
                            android:inputType="numberPassword"
                            android:maxLength="3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Mobile Wallet -->
                <RadioButton
                    android:id="@+id/radioWallet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mobile_wallet" />

                <LinearLayout
                    android:id="@+id/layoutMobileDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingStart="32dp"
                    android:paddingEnd="0dp"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orange" android:background="#FF6600" android:textColor="#FFFFFF" android:padding="4dp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MyZaka" android:background="#00AEEF" android:textColor="#FFFFFF" android:padding="4dp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smega" android:background="#FFD700" android:textColor="#000000" android:padding="4dp" android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_provider"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerMobileProvider"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />

                    <EditText
                        android:id="@+id/editMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/mobile_number_hint"
                        android:inputType="phone" />
                </LinearLayout>

            </RadioGroup>

            <Button
                android:id="@+id/btnPay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_primary_button"
                android:text="@string/pay_and_reserve"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV ICONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center">

        <ImageButton android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_today" app:tint="#777799" android:contentDescription="@string/nav_home" />
        <ImageButton android:id="@+id/navSaved" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/btn_star_big_on" app:tint="#777799" android:contentDescription="@string/nav_saved" />
        <ImageButton android:id="@+id/navChat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/stat_notify_chat" app:tint="#777799" android:contentDescription="@string/nav_chat" />
        <ImageButton android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_myplaces" app:tint="#777799" android:contentDescription="@string/nav_profile" />
    </LinearLayout>

</LinearLayout>