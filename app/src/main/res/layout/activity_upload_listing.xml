<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HEADER AREA -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBackToDashboard"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_primary"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:text="Upload Property"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </RelativeLayout>

        <!-- TITLE / SUMMARY CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Listing Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Name"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etUploadTitle"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="e.g. Cozy Broadhurst Studio"
                    android:textColorHint="@color/text_secondary"
                    android:inputType="textCapWords"
                    android:padding="14dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <!-- Rent Price -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Rent (P)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etUploadPrice"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="e.g. 3500"
                    android:textColorHint="@color/text_secondary"
                    android:inputType="number"
                    android:padding="14dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <!-- Location Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input">

                    <Spinner
                        android:id="@+id/spinnerUploadLocation"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingHorizontal="4dp" />
                </FrameLayout>

                <!-- House Type Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accommodation Type"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input">

                    <Spinner
                        android:id="@+id/spinnerUploadHouseType"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingHorizontal="4dp" />
                </FrameLayout>

                <!-- Availability Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available From Date"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etUploadDate"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="Select date"
                    android:textColorHint="@color/text_secondary"
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="14dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:drawableEnd="@android:drawable/ic_menu_myplaces"
                    android:drawableTint="@color/text_secondary" />

                <!-- Property Images Upload -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Images"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btnUploadSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose Image"
                        android:backgroundTint="@color/bg_accent"
                        android:textColor="@color/color_primary"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />

                    <TextView
                        android:id="@+id/txtUploadedImageName"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="No images selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgUploadPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="@color/bg_accent"
                    android:contentDescription="Property Preview" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Upload Button -->
        <Button
            android:id="@+id/btnSubmitUpload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_primary_button"
            android:text="Submit Property Listing"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
