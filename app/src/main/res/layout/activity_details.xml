<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Slider -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="320dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerDetails"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_card"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/text_primary"
                    android:contentDescription="@string/back" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabDotsDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="12dp"
                    app:tabBackground="@android:drawable/presence_online"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="10dp"
                    app:tabRippleColor="@null" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtDetailsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Housing"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/txtDetailsPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="P1200 / month"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="20dp" />

                <TextView
                    android:id="@+id/txtDetailsLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/text_secondary" />

                <TextView
                    android:id="@+id/txtDetailsDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Available From"
                    android:textSize="16sp"
                    android:textColor="@color/color_success"
                    app:drawableStartCompat="@android:drawable/ic_menu_today"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/color_success" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Accommodation Description"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/ai_desc_default"
                    android:textSize="15sp"
                    android:textColor="@color/text_body"
                    android:lineSpacingExtra="6dp" />

                <Button
                    android:id="@+id/btnReserve"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/bg_primary_button"
                    android:text="Reserve Now"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnChat"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Chat with Provider"
                    android:textAllCaps="false"
                    android:textColor="@color/color_primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav Icons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:elevation="8dp"
        android:gravity="center">

        <ImageButton android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_today" app:tint="@color/tint_icon_active" android:contentDescription="@string/nav_home" />
        <ImageButton android:id="@+id/navSaved" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/btn_star_big_on" app:tint="@color/tint_icon_inactive" android:contentDescription="@string/nav_saved" />
        <ImageButton android:id="@+id/navChat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/stat_notify_chat" app:tint="@color/tint_icon_inactive" android:contentDescription="@string/nav_chat" />
        <ImageButton android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/tint_icon_inactive" android:contentDescription="@string/nav_profile" />
    </LinearLayout>

</LinearLayout>